{
    "name": "codesaur/template",
    "description": "Бие даасан PHP template engine. Хөгжлийн явцад Twig-ийн синтаксаас санаа авч чадамжуудаа өргөжүүлсэн. Filters, functions, macros, expression parser бүхий хөнгөн, хурдан загварчлагч",
    "keywords": [
        "template", "template-engine", "html", "php", "filters", "macros",
        "mongol", "mongolia", "монгол", "codesaur", "narankhuu", "coden", "кодзавр", "наранхүү", "коден"
    ],
    "homepage": "https://github.com/codesaur-php",
    "authors": [
        {
            "name": "Narankhuu (+976 99000287)",
            "email": "codesaur@gmail.com",
            "homepage": "https://github.com/codesaur"
        }
    ],
    "require": {
        "php": "^8.2.1",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "codesaur\\Template\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "codesaur\\Template\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@php vendor/bin/phpunit --configuration phpunit.xml.dist"
        ],
        "test-coverage": [
            "@php -d xdebug.mode=coverage vendor/bin/phpunit --configuration phpunit.xml.dist --coverage-html coverage"
        ]
    },
    "license": "MIT",
    "minimum-stability": "dev"
}
